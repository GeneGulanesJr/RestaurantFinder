# OpenRouter API key for LLM (natural language interpretation)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Foursquare API key for Place Search
FOURSQUARE_API_KEY=your_foursquare_api_key_here

# Session signing secret (min 16 chars) for login cookie
SESSION_SECRET=your_session_secret_min_16_chars

# Demo credentials for login (optional, defaults shown)
DEMO_USERNAME=demo
DEMO_PASSWORD=1234

# Session TTL in seconds (optional, default: 604800 = 7 days)
SESSION_TTL_SEC=604800

# API timeout in milliseconds (optional, default: 15000 = 15 seconds)
OPENROUTER_TIMEOUT_MS=15000
FOURSQUARE_TIMEOUT_MS=15000
